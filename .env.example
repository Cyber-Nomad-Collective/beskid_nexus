# Beskid Nexus — single `gitnexus serve` process (API, MCP, static UI)

# ── Server ───────────────────────────────────────────────────────────────────
GITNEXUS_HOME=.data/gitnexus
PORT=8452
GITNEXUS_SERVE_HOST=0.0.0.0
NODE_ENV=development

# Bearer token for /api/* (except health, auth, public catalog). Required in production for MCP.
NEXUS_MCP_AUTH_TOKEN=

# ── GitHub OAuth (optional at first boot — can be saved via /setup UI) ─────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# e.g. http://localhost:5173/api/auth/callback (dev) or https://nexus.example.com/api/auth/callback
GITHUB_OAUTH_CALLBACK_URL=
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars-long

# Comma-separated GitHub logins allowed to manage the repo catalog
NEXUS_ADMIN_GITHUB_LOGINS=

# One-time token for POST /api/admin/setup when OAuth env vars are unset
NEXUS_SETUP_TOKEN=

# GitHub App / repo webhook secret for push-triggered re-index
GITHUB_WEBHOOK_SECRET=

# ── Web dev (Vite) ───────────────────────────────────────────────────────────
# Proxy target for `bun run dev` in gitnexus-web (defaults to http://127.0.0.1:8452)
VITE_API_PROXY_TARGET=http://127.0.0.1:8452

# Optional deep-link default (?project=); leave empty for catalog-first home
VITE_NEXUS_DEFAULT_REPO=

{
  "name": "beskid-nexus",
  "private": true,
  "description": "Beskid compiler knowledge graph (GitNexus fork)",
  "scripts": {
    "build:shared": "npm run build --prefix gitnexus-shared",
    "build:web": "npm run build --prefix gitnexus-web",
    "build:cli": "npm run build --prefix gitnexus",
    "build": "npm run build:shared && npm run build:cli && npm run build:web",
    "dev:web": "npm run dev --prefix gitnexus-web",
    "format": "prettier --write \"gitnexus-web/src/**/*.{ts,tsx,css}\" \"*.{md,json,yml}\"",
    "format:check": "prettier --check \"gitnexus-web/src/**/*.{ts,tsx,css}\" \"*.{md,json,yml}\""
  },
  "devDependencies": {
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.0"
  }
}
